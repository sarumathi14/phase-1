    "import numpy as np\n",
    "import pandas as pd\n",
    "data = pd.DataFrame({\n",
    "    'id': range(1, 101),\n",
    "    'value': np.random.randint(1, 100, size=100)\n",
    "})\n",
    "sample_size = 10\n",
    "random_sample = data.sample(n=sample_size, random_state=42)\n",
    "print(\"Simple Random Sample:\")\n",
    "print(random_sample)"
   ]
